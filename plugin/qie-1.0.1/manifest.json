{
  "pluginId": "qie",
  "version": "1.0.1",
  "apiVersion": 1,
  "displayName": "企鹅体育",
  "platformDescription": "体育赛事与综合内容直播平台",
  "liveTypes": [
    "10"
  ],
  "entry": "index.js",
  "preloadScripts": [],
  "auth": {
    "required": false,
    "credentialKinds": [],
    "supportsStatusCheck": false,
    "supportsValidation": false
  },
  "capabilities": {
    "categories": {
      "status": "available"
    },
    "rooms": {
      "status": "unavailable"
    },
    "playback": {
      "status": "available"
    },
    "search": {
      "status": "available"
    },
    "roomDetail": {
      "status": "available"
    },
    "liveState": {
      "status": "available"
    },
    "shareResolve": {
      "status": "available"
    },
    "danmaku": {
      "status": "unavailable"
    }
  },
  "changelog": [
    "1.0.1：开放搜索入口，支持输入企鹅体育房间号或房间链接添加直播间",
    "1.0.0：支持免登录获取分类、房间详情、开播状态和时效 FLV 播放地址",
    "实现企鹅体育网页端分钟签名，并支持播放地址刷新",
    "支持房间号和 qie.tv 房间链接解析"
  ],
  "shareResolve": {
    "hosts": [
      "qie.tv",
      "live.qq.com"
    ]
  },
  "hostBehavior": {
    "playableLiveStates": [
      "1"
    ],
    "externalRoomURLTemplate": "https://www.qie.tv/{roomId}",
    "themeColor": "#19BE6B"
  }
}
