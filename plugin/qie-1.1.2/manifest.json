{
  "pluginId": "qie",
  "version": "1.1.2",
  "apiVersion": 1,
  "displayName": "企鹅体育",
  "platformDescription": "体育赛事与综合内容直播平台",
  "liveTypes": [
    "10"
  ],
  "entry": "index.js",
  "preloadScripts": [
    "lp_plugin_qie_1.1.2_danmaku.js"
  ],
  "auth": {
    "required": false,
    "credentialKinds": [],
    "supportsStatusCheck": false,
    "supportsValidation": false
  },
  "capabilities": {
    "categories": {
      "status": "available"
    },
    "rooms": {
      "status": "unavailable"
    },
    "playback": {
      "status": "available"
    },
    "search": {
      "status": "available"
    },
    "roomDetail": {
      "status": "available"
    },
    "liveState": {
      "status": "available"
    },
    "shareResolve": {
      "status": "available"
    },
    "danmaku": {
      "status": "available",
      "driver": "plugin_js_v1",
      "transport": "websocket",
      "protocolId": "qie_ws_binary",
      "protocolVersion": "1"
    }
  },
  "changelog": [
    "1.1.2：修复多清晰度 requestContext 类型导致 iOS 解码失败；补充 clearCredential 无登录兼容方法",
    "1.1.1：按企鹅体育网页接口实际返回的流数量动态显示清晰度，并在刷新播放地址时保持所选档位",
    "1.1.0：支持企鹅体育免登录 WebSocket 实时弹幕；Big/Small 平台图标改为透明背景",
    "1.0.2：补充官方平台图标；房间页面未返回 owner_avatar 时，通过官方用户信息接口补齐主播头像",
    "1.0.1：开放搜索入口，支持输入企鹅体育房间号或房间链接添加直播间",
    "1.0.0：支持免登录获取分类、房间详情、开播状态和时效 FLV 播放地址",
    "实现企鹅体育网页端分钟签名，并支持播放地址刷新",
    "支持房间号和 qie.tv 房间链接解析"
  ],
  "shareResolve": {
    "hosts": [
      "qie.tv",
      "live.qq.com"
    ]
  },
  "hostBehavior": {
    "playableLiveStates": [
      "1"
    ],
    "externalRoomURLTemplate": "https://www.qie.tv/{roomId}",
    "themeColor": "#19BE6B"
  }
}
